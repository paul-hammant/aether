// Hello World - Your first Aether program
// Run with: ae run examples/basics/hello.ae

main() {
    print("Hello, Aether!\n");

    // Variables with type inference
    x = 42;
    y = 8;

    if (x > y) {
        print("x is greater than y\n");
    }

    // Simple arithmetic
    sum = x + y;
    print("Sum: ");
    print(sum);
    print("\n");

    print("Welcome to Aether!\n");
}
